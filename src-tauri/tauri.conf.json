{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Evolvria",
  "version": "0.1.0",
  "identifier": "com.evolvria.client",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:5174",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Evolvria",
        "width": 1440,
        "height": 900,
        "minWidth": 390,
        "minHeight": 640,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/icon.png"
    ]
  }
}
